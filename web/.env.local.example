# ── Option A: local emulator (no real Firebase project needed) ─────────────
# Fastest way for anyone to actually run and click through the app — points
# at the same local Firebase Emulator Suite the acceptance test scripts use.
# Start it first: firebase emulators:start --only auth,firestore,functions,storage --project demo-laetiva
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-laetiva

# ── Option B: a real Firebase project ───────────────────────────────────────
# Leave NEXT_PUBLIC_USE_FIREBASE_EMULATOR unset/false and fill these in
# instead. Get them from Firebase Console > Project Settings > General >
# Your apps > Web app, or via:
#   firebase apps:sdkconfig web --project laetiva-dev
# These are public client identifiers, not secrets — safe to ship in the
# bundle — but real values must come from the actual Firebase project, not
# be guessed.
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional: Firebase App Check reCAPTCHA v3 site key (Option B only). Leave
# blank to run without App Check (functions run in monitor mode, per
# appCheck.ts).
# NEXT_PUBLIC_FIREBASE_APPCHECK_SITE_KEY=
