rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function role() {
      return isSignedIn()
        ? request.auth.token.get('role', null)
        : null;
    }

    function isAdmin() {
      return role() == 'admin';
    }

    function isSuperAdmin() {
      return isAdmin() &&
             ('adminRoleIds' in request.auth.token) &&
             ('super_admin' in request.auth.token.adminRoleIds);
    }

    function isCmsImage() {
      return request.resource.contentType.matches('image/(jpeg|jpg|png|webp)');
    }

    function isVendor() {
      return role() == 'vendor';
    }

    function tokenVendorId() {
      return isSignedIn()
        ? request.auth.token.get('vendorId', null)
        : null;
    }

    function isVendorOwner(vendorId) {
      return isVendor() &&
             tokenVendorId() == vendorId;
    }

    function isImage() {
      return request.resource.contentType.matches(
        'image/(jpeg|jpg|png|webp|heic)'
      );
    }

    function isPdfOrImage() {
      return request.resource.contentType == 'application/pdf'
          || request.resource.contentType.matches(
               'image/(jpeg|jpg|png|webp|heic)'
             );
    }

    function underMb(maxMb) {
      return request.resource.size <
             (maxMb * 1024 * 1024);
    }

    // ==========================================================
    // User profile photos
    // ==========================================================
    match /users/{userId}/{fileName} {

      allow read: if true;

      allow create, update: if
        isSignedIn()
        && uid() == userId
        && isImage()
        && underMb(5);

      allow delete: if
        isSignedIn()
        && uid() == userId;
    }

    // ==========================================================
    // Vendor public media
    // ==========================================================
    match /vendorMedia/{vendorId}/logos/{fileId} {

      allow read: if true;

      allow create, update: if
        isVendorOwner(vendorId)
        && isImage()
        && underMb(5);

      allow delete: if
        isVendorOwner(vendorId);
    }

    match /vendorMedia/{vendorId}/banners/{fileId} {

      allow read: if true;

      allow create, update: if
        isVendorOwner(vendorId)
        && isImage()
        && underMb(8);

      allow delete: if
        isVendorOwner(vendorId);
    }

    match /vendorMedia/{vendorId}/gallery/{fileId} {

      allow read: if true;

      allow create, update: if
        isVendorOwner(vendorId)
        && isImage()
        && underMb(8);

      allow delete: if
        isVendorOwner(vendorId);
    }

    // ==========================================================
    // Invoice branding logos (Phase 4) — the vendor uploads here first,
    // then references the path via updateInvoiceBranding, which validates
    // the real object's content type/size server-side before accepting it
    // (client-declared metadata is never trusted). Read is admin/vendor-
    // owner only; the PDF renderer runs server-side with the Admin SDK,
    // which bypasses these rules entirely, so no public read is needed.
    // ==========================================================
    match /invoiceBranding/{vendorId}/{fileId} {

      allow read: if isVendorOwner(vendorId) || isAdmin();

      allow create, update: if
        isVendorOwner(vendorId)
        && isImage()
        && underMb(2);

      allow delete: if isVendorOwner(vendorId);
    }

    // ==========================================================
    // Landing Page CMS images (LANDING_PAGE_CMS_VENDOR_PORTAL_MAPPING.md
    // Section 2.4). Publicly readable (used on public pages); write is
    // Super-Admin only, JPEG/PNG/WebP only (SVG rejected — XSS risk), max
    // 10MB, server-side compression/resizing happens at CMS-editor upload
    // time. Note: this check is custom-claims-only (Storage rules cannot
    // query Firestore), so unlike assertAdmin's live adminUsers status
    // check, a just-revoked Super-Admin's existing token could still
    // upload until it naturally expires (up to 1 hour) — an accepted MVP
    // tradeoff, same shape as App Check's monitor-mode gap.
    // ==========================================================
    match /siteContent/{fileId} {

      allow read: if true;

      allow create, update: if
        isSuperAdmin()
        && isCmsImage()
        && underMb(10);

      allow delete: if isSuperAdmin();
    }

    // ==========================================================
    // Verification documents
    // ==========================================================
    match /verificationDocuments/{vendorId}/{docId} {

      allow read: if isAdmin();

      allow create: if
        isVendorOwner(vendorId)
        && isPdfOrImage()
        && underMb(15);

      allow update: if false;

      allow delete: if isAdmin();
    }

    // ==========================================================
    // Default deny
    // ==========================================================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
